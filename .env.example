# Copy to .env and adjust. All settings are overridable via DOCAI_* env vars.
DOCAI_OCR__LANG=eng+fra
DOCAI_OCR__PSM=3

# Pipeline feature flags (API)
DOCAI_ENABLE_PREPROCESS=1
DOCAI_ENABLE_VISION=0
DOCAI_ENABLE_CLS=0
DOCAI_ENABLE_NER=0

# Model checkpoints (set once fine-tuned)
DOCAI_VISION__WEIGHTS=models/layout/best.pt
DOCAI_NLP__CLASSIFIER_MODEL=models/report-classifier
DOCAI_NLP__NER_MODEL=models/ner
DOCAI_NLP__DEVICE=cpu
